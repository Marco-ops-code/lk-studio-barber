PORT=3000
APP_URL=http://localhost:3000
ADMIN_PASSWORD=admin123

# Dossier persistant pour la base (réservations, paramètres)
# En local : laisser vide (utilise ./data)
# En production (Render, etc.) : /var/data
DATA_DIR=

# Stripe (Phase 4) — laissez vide pour mode simulation
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email SMTP (Phase 5) — laissez vide pour mode simulation (journal local)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# SMS Twilio (Phase 5, optionnel)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
